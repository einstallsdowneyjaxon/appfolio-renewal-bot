APPFOLIO_URL=https://thetgpm.appfolio.com
APPFOLIO_USERNAME=
APPFOLIO_PASSWORD=

# Persistent browser profile for AppFolio cookies/localStorage/session.
PLAYWRIGHT_USER_DATA_DIR=.playwright-appfolio-profile

# Optional one-time/manual recovery only. Normal n8n runs should reuse the persistent session.
APPFOLIO_MFA_CODE=
APPFOLIO_LOGIN_TIMEOUT_MS=60000
APPFOLIO_ACTION_TIMEOUT_MS=30000
APPFOLIO_DIAGNOSTIC_MODE=true

# Optional automated MFA recovery. Used only when AppFolio asks for 2FA.
GETMYMFA_URL=https://client.get.mymfa.io/
GETMYMFA_USERNAME=
GETMYMFA_PASSWORD=
GETMYMFA_PHONE_NUMBER=+16266104061

LEASE_RENEWAL_SPREADSHEET=Lease_renewals_owner
LEASE_RENEWAL_SPREADSHEET_ID=1dJBcNkXn2fVwgK1kETR5Sp4QuwyAIyhwjyAQ9BL5MBM
LEASE_RENEWAL_TAB=Coco_XR

# Required unless n8n passes N8N_PAYLOAD/N8N_INPUT/N8N_JSON/LEASE_RENEWAL_PAYLOAD.
# Supported payload keys: rowNumber, row, sheetRow, leaseRenewalRow, row_number, sheet_row.
LEASE_RENEWAL_ROW=

# Example n8n payload:
# N8N_PAYLOAD={"rowNumber":2}

